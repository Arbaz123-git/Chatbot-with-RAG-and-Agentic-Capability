# ===========================================
# REQUIRED ENVIRONMENT VARIABLES
# ===========================================

# Groq API Key (required) - Get from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# LangSearch API Key (required for web search in agent mode)
LANGSEARCH_API_KEY=your_langsearch_api_key_here

# ===========================================
# OPTIONAL: LLM SETTINGS
# ===========================================

# Main chat model settings
# GROQ_MODEL=openai/gpt-oss-120b
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# TEMPERATURE=0.0
# MAX_TOKENS=2048

# Agent model settings
# AGENT_MODEL=llama-3.3-70b-versatile
# AGENT_TEMPERATURE=0.0
# AGENT_MAX_TOKENS=4096

# Evaluator model settings
# EVALUATOR_MODEL=groq/compound
# EVALUATOR_TEMPERATURE=0.1

# ===========================================
# OPTIONAL: RAG SETTINGS
# ===========================================

# Document chunking
# CHUNK_SIZE=800
# CHUNK_OVERLAP=200

# Vector search
# TOP_K_RESULTS=3
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# CHROMA_PERSIST_DIR=./data/chroma_db

# ===========================================
# OPTIONAL: FEATURE FLAGS
# ===========================================

# Enable/disable web search in agent mode
# WEB_SEARCH_ENABLED=false
